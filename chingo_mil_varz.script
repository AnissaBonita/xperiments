// 2. LENTES / GAFAS (glassesa)
//========================================================
output2
  glassesa is [joinLists(glassesaList, glassesaValues)]

glassesaList
  Default 
    prompt = {|}
  🎲 Random
    prompt = [glassesaValues.selectOne.prompt]

glassesaValues
  Blindfold
    prompt = She is blindfolded
  Glasses 
    prompt = She is wearing glasses.
  Glasses Aviator 
    prompt = She is wearing aviator style glasses
  Glasses Big 
    prompt = She is wearing big white framed glasses
  Glasses Cat-eye
    prompt = She is wearing cat eye shaped glasses. It is very important that her glasses are oval shaped. She is wearing cat glasses. Her glasses frames are cat eye shape. Her glasses shape is thin oval. Her glasses have an upsweep at the outer edges where the arms join the frame front. 
  Glasses Clubmaster 
    prompt = She is wearing clubmaster style glasses
  Glasses Granny
    prompt = She is wearing oversized, oval-framed granny glasses with a nostalgic, gentle charm and intellectual vibe.
